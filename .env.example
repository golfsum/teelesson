# Firebase Web config — copy to `.env` and fill with your project's values.
# Find these in Firebase Console > Project settings > General > Your apps (Web).
# All client-side Expo env vars MUST be prefixed with EXPO_PUBLIC_.

EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: set to 1 to force the built-in demo dataset (12 players + lessons)
# even when Firebase is configured. Useful for previewing the populated UI.
# Leave unset/0 to use live Firestore data.
# EXPO_PUBLIC_DEMO_DATA=1

# Optional: set to true to show the pre-launch "Coming Soon" holding page instead
# of the app (used in production).
# EXPO_PUBLIC_COMING_SOON=true

# Dev preview only (works with the bypass login): which side to open.
# "coach" (default) or "player".
# EXPO_PUBLIC_DEV_MOCK_USER=player

# Set to 0 to exercise the real signed-out landing and Firebase auth flow.
# Leave unset for deterministic local coach/player previews. Production builds
# always use Firebase auth, regardless of this development-only switch.
# EXPO_PUBLIC_DEV_SKIP_AUTH=0
